<% content_for :title, @ebook.title %>

<%= render "shared/page_header",
    title: @ebook.title,
    subtitle: @ebook.author do %>

  <%= link_to "← Back",
      ebooks_path,
      class: "rounded-lg border border-slate-300 px-5 py-2.5 text-slate-700 hover:bg-slate-100" %>

<% end %>

<div class="grid gap-8 lg:grid-cols-3">

  <div>

    <% if @ebook.cover_image.attached? %>

      <%= image_tag @ebook.cover_image,
          class: "w-full rounded-xl shadow-lg object-cover" %>

    <% else %>

      <div class="flex h-96 items-center justify-center rounded-xl bg-slate-100 text-8xl">
        📕
      </div>

    <% end %>

  </div>

  <div class="space-y-6 lg:col-span-2">

    <div class="rounded-xl bg-white p-6 shadow">

      <h1 class="text-3xl font-bold text-slate-900">
        <%= @ebook.title %>
      </h1>

      <p class="mt-2 text-lg text-slate-600">
        <%= @ebook.author %>
      </p>

      <div class="mt-6 border-t pt-6">

        <dl class="space-y-4">

          <div class="flex justify-between">
            <dt class="font-medium text-slate-600">
              Published
            </dt>

            <dd>
              <%= @ebook.published_at.strftime("%d %B %Y") %>
            </dd>
          </div>

          <div class="flex justify-between">
            <dt class="font-medium text-slate-600">
              PDF
            </dt>

            <dd>
              <% if @ebook.pdf_file.attached? %>
                <span class="rounded-full bg-green-100 px-3 py-1 text-sm text-green-700">
                  Available
                </span>
              <% else %>
                <span class="rounded-full bg-red-100 px-3 py-1 text-sm text-red-700">
                  Missing
                </span>
              <% end %>
            </dd>
          </div>

        </dl>

      </div>

      <div class="mt-6">

        <h2 class="mb-2 text-lg font-semibold">
          Description
        </h2>

        <p class="leading-7 text-slate-600">
          <%= @ebook.description.presence || "No description available." %>
        </p>

      </div>

    </div>

    <div class="flex flex-wrap gap-3">

      <% if @ebook.pdf_file.attached? %>

        <%= link_to "📖 Read",
            read_ebook_path(@ebook),
            class: "rounded-lg bg-indigo-600 px-5 py-3 text-white hover:bg-indigo-700" %>

        <%= link_to "⬇ Download",
            download_ebook_path(@ebook),
            class: "rounded-lg bg-emerald-600 px-5 py-3 text-white hover:bg-emerald-700" %>

      <% end %>

      <%= link_to "✏ Edit",
          edit_ebook_path(@ebook),
          class: "rounded-lg bg-amber-500 px-5 py-3 text-white hover:bg-amber-600" %>

      <%= link_to "🗑 Delete",
          ebook_path(@ebook),
          data: {
            turbo_method: :delete,
            turbo_confirm: "Are you sure you want to delete this ebook?"
          },
          class: "rounded-lg bg-red-600 px-5 py-3 text-white hover:bg-red-700" %>

    </div>

  </div>

</div>