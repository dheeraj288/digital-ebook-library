<% content_for :title, @ebook.title %>

<div class="mb-6">
  <%= link_to "← Back to Library",
      ebooks_path,
      class: "text-indigo-600 hover:text-indigo-700 font-medium" %>
</div>

<div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-lg">

  <div class="grid grid-cols-1 lg:grid-cols-3">

    <!-- Cover -->
    <div class="bg-slate-100 p-6">

      <% if @ebook.cover_image.attached? %>

        <%= image_tag @ebook.cover_image,
            class: "w-full rounded-xl object-cover shadow-md" %>

      <% else %>

        <div class="flex h-[500px] items-center justify-center rounded-xl bg-slate-200 text-8xl">
          📕
        </div>

      <% end %>

    </div>

    <!-- Details -->
    <div class="lg:col-span-2 p-8">

      <div class="flex items-start justify-between">

        <div>

          <h1 class="text-4xl font-bold text-slate-900">
            <%= @ebook.title %>
          </h1>

          <p class="mt-2 text-lg text-slate-600">
            by <strong><%= @ebook.author %></strong>
          </p>

        </div>

        <span class="rounded-full bg-indigo-100 px-4 py-2 text-sm font-medium text-indigo-700">
          <%= @ebook.published_at.year %>
        </span>

      </div>

      <hr class="my-8">

      <h2 class="mb-3 text-lg font-semibold">
        Description
      </h2>

      <p class="leading-7 text-slate-600">
        <%= @ebook.description %>
      </p>

      <hr class="my-8">

      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">

        <div class="rounded-lg bg-slate-50 p-4">
          <p class="text-sm text-slate-500">
            Published Date
          </p>

          <p class="mt-1 font-semibold">
            <%= @ebook.published_at.strftime("%d %B %Y") %>
          </p>
        </div>

        <div class="rounded-lg bg-slate-50 p-4">
          <p class="text-sm text-slate-500">
            Added To Library
          </p>

          <p class="mt-1 font-semibold">
            <%= @ebook.created_at.strftime("%d %B %Y") %>
          </p>
        </div>

        <% if @ebook.pdf_file.attached? %>

          <div class="rounded-lg bg-slate-50 p-4">
            <p class="text-sm text-slate-500">
              PDF Size
            </p>

            <p class="mt-1 font-semibold">
              <%= number_to_human_size(@ebook.pdf_file.byte_size) %>
            </p>
          </div>

          <div class="rounded-lg bg-slate-50 p-4">
            <p class="text-sm text-slate-500">
              File Name
            </p>

            <p class="mt-1 truncate font-semibold">
              <%= @ebook.pdf_file.filename %>
            </p>
          </div>

        <% end %>

      </div>

      <div class="mt-10 flex flex-wrap gap-3">

        <%= link_to "📖 Read",
            read_ebook_path(@ebook),
            class: "rounded-lg bg-indigo-600 px-6 py-3 font-medium text-white hover:bg-indigo-700" %>

        <%= link_to "⬇ Download",
            download_ebook_path(@ebook),
            class: "rounded-lg bg-emerald-600 px-6 py-3 font-medium text-white hover:bg-emerald-700" %>

        <%= link_to "✏ Edit",
            edit_ebook_path(@ebook),
            class: "rounded-lg bg-amber-500 px-6 py-3 font-medium text-white hover:bg-amber-600" %>

        <%= button_to "🗑 Delete",
            ebook_path(@ebook),
            method: :delete,
            form: {
              data: {
                turbo_confirm: "Are you sure you want to delete this ebook?"
              }
            },
            class: "rounded-lg bg-red-600 px-6 py-3 font-medium text-white hover:bg-red-700" %>

      </div>

    </div>

  </div>

</div>