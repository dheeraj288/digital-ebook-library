<% content_for :title, @ebook.title %>

<%= render "shared/page_header",
    title: @ebook.title,
    subtitle: "Written by #{@ebook.author}" do %>

  <%= link_to "← Back",
      ebooks_path,
      class: "rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100" %>

<% end %>

<div class="mx-auto max-w-6xl">

  <div class="grid gap-10 rounded-xl bg-white p-8 shadow lg:grid-cols-3">

    <div>
      <% if @ebook.cover_image.attached? %>
        <%= image_tag @ebook.cover_image, class: "w-full rounded-xl shadow-lg" %>
      <% else %>
        <div class="flex h-[500px] items-center justify-center rounded-xl bg-slate-100 text-8xl">
          📕
        </div>
      <% end %>
    </div>

    <div class="lg:col-span-2">
      <h1 class="text-4xl font-bold text-slate-900">
        <%= @ebook.title %>
      </h1>

      <p class="mt-3 text-lg text-slate-600">
        <strong>Author:</strong>
        <%= @ebook.author %>
      </p>

      <% if @ebook.published_at.present? %>
        <p class="mt-2 text-slate-500">
          <strong>Published:</strong>
          <%= @ebook.published_at.strftime("%d %B %Y") %>
        </p>
      <% end %>

      <div class="mt-8">
        <h2 class="mb-3 text-xl font-semibold">Description</h2>
        <p class="leading-8 text-slate-600">
          <%= @ebook.description.presence || "No description available." %>
        </p>
      </div>

      <div class="mt-10 flex flex-wrap gap-4">
        <% if @ebook.pdf_file.attached? %>
          <%= link_to "📖 Read PDF",
              read_ebook_path(@ebook),
              class: "rounded-lg bg-indigo-600 px-6 py-3 text-white hover:bg-indigo-700" %>

          <%= link_to "⬇ Download PDF",
              download_ebook_path(@ebook),
              class: "rounded-lg bg-emerald-600 px-6 py-3 text-white hover:bg-emerald-700" %>
        <% end %>

        <%= link_to "✏ Edit",
            edit_ebook_path(@ebook),
            class: "rounded-lg bg-amber-500 px-6 py-3 text-white hover:bg-amber-600" %>

        <%= link_to "🗑 Delete",
            ebook_path(@ebook),
            data: {
              turbo_method: :delete,
              turbo_confirm: "Are you sure you want to delete this ebook?"
            },
            class: "rounded-lg bg-red-600 px-6 py-3 text-white hover:bg-red-700" %>
      </div>
    </div>
  </div>
</div>