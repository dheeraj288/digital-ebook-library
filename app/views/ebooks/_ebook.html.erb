<div class="flex h-full flex-col overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-xl">

  <% if ebook.cover_image.attached? %>
    <%= image_tag ebook.cover_image, class: "h-72 w-full object-cover" %>
  <% else %>
    <div class="flex h-72 items-center justify-center bg-slate-100 text-6xl">
      📕
    </div>
  <% end %>

  <div class="flex flex-1 flex-col p-5">

    <h2 class="truncate text-lg font-semibold text-slate-900">
      <%= ebook.title %>
    </h2>

    <p class="mt-1 text-sm text-slate-600">
      <%= ebook.author %>
    </p>

    <% if ebook.description.present? %>
      <p class="mt-3 line-clamp-3 flex-1 text-sm text-slate-500">
        <%= ebook.description %>
      </p>
    <% else %>
      <p class="mt-3 flex-1 text-sm italic text-slate-400">
        No description available.
      </p>
    <% end %>

    <div class="mt-5 flex gap-2">

      <%= link_to "View",
          ebook_path(ebook),
          class: "flex-1 rounded-lg bg-indigo-600 py-2 text-center text-sm font-medium text-white hover:bg-indigo-700" %>


      <%= link_to "Edit",
          edit_ebook_path(ebook),
          class: "rounded-lg bg-amber-500 px-4 py-2 text-sm font-medium text-white hover:bg-amber-600" %>


      <%= link_to "Delete",
          ebook_path(ebook),
          data: {
            turbo_method: :delete,
            turbo_confirm: "Are you sure you want to delete '#{ebook.title}'?"
          },
          class: "rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700" %>

    </div>

  </div>

</div>