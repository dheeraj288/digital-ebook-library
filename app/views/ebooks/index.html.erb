<% content_for :title, "Ebook Library" %>

<%= render "shared/page_header",
    title: "Ebook Library",
    subtitle: "Manage your digital collection." do %>

  <%= link_to "Upload Ebook",
      new_ebook_path,
      class: "rounded-lg bg-indigo-600 px-5 py-2.5 text-white transition hover:bg-indigo-700" %>

<% end %>

<!-- Dashboard Stats -->
<%= render "shared/stats" %>

<div class="mb-8 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">

  <%= form_with url: ebooks_path,
      method: :get,
      local: true do |form| %>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-5">

      <%= form.text_field :query,
          value: @query,
          placeholder: "Search title or author...",
          class: "rounded-lg border border-slate-300 px-4 py-3 focus:border-indigo-500 focus:outline-none" %>

      <%= form.select :author,
          options_for_select(@authors, @author),
          { include_blank: "All Authors" },
          class: "rounded-lg border border-slate-300 px-4 py-3" %>

      <%= form.select :year,
          options_for_select(@years, @year),
          { include_blank: "All Years" },
          class: "rounded-lg border border-slate-300 px-4 py-3" %>

      <%= form.select :sort,
          options_for_select(
            [
              ["Newest", "newest"],
              ["Oldest", "oldest"],
              ["Title A-Z", "title_asc"],
              ["Title Z-A", "title_desc"]
            ],
            @sort
          ),
          {},
          class: "rounded-lg border border-slate-300 px-4 py-3" %>

      <div class="flex gap-2">

        <%= form.submit "Apply",
            class: "flex-1 rounded-lg bg-indigo-600 px-5 py-3 text-white hover:bg-indigo-700" %>

        <%= link_to "Reset",
            ebooks_path,
            class: "rounded-lg border border-slate-300 px-5 py-3 hover:bg-slate-100" %>

      </div>

    </div>

  <% end %>

</div>

<%= render "ebooks", ebooks: @ebooks %>

<% if @pagy.pages > 1 %>
  <div class="mt-10 flex justify-center">
    <%== pagy_nav(@pagy) %>
  </div>
<% end %>