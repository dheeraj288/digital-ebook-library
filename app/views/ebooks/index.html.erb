<% content_for :title, "Ebook Library" %>

<%= render "shared/page_header",
    title: "Ebook Library",
    subtitle: "Manage your digital collection." do %>

  <%= link_to "Upload Ebook",
      new_ebook_path,
      class: "rounded-lg bg-indigo-600 px-5 py-2.5 text-white hover:bg-indigo-700" %>

<% end %>

<% if @ebooks.any? %>

  <div class="space-y-4">

    <% @ebooks.each do |ebook| %>

    <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-lg">

      <% if ebook.cover_image.attached? %>
        <%= image_tag ebook.cover_image,
            class: "h-72 w-full object-cover" %>
      <% else %>
        <div class="flex h-72 items-center justify-center bg-slate-100 text-6xl">
          📕
        </div>
      <% end %>

      <div class="space-y-2 p-4">

        <h2 class="truncate text-lg font-semibold text-slate-900">
          <%= ebook.title %>
        </h2>

        <p class="text-sm text-slate-600">
          <%= ebook.author %>
        </p>

        <% if ebook.description.present? %>
          <p class="line-clamp-2 text-sm text-slate-500">
            <%= ebook.description %>
          </p>
        <% end %>

      </div>

    </div>
    <% end %>

  </div>

<% else %>

  <%= render "shared/empty_state",
      title: "No ebooks yet",
      description: "Upload your first ebook." do %>

      <%= link_to "Upload Ebook",
          new_ebook_path,
          class: "rounded-lg bg-indigo-600 px-5 py-2.5 text-white hover:bg-indigo-700" %>

  <% end %>

<% end %>