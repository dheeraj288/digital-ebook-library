<% content_for :title, "Ebook Library" %>

<%= render "shared/page_header",
    title: "Ebook Library",
    subtitle: "Manage your digital collection." do %>

    <div class="mb-8">
  <%= form_with url: ebooks_path,
                method: :get,
                local: true do |form| %>

    <div class="flex gap-3">

      <%= form.text_field :query,
          value: params[:query],
          placeholder: "Search by title or author...",
          class: "w-full rounded-lg border border-slate-300 px-4 py-3 focus:border-indigo-500 focus:outline-none" %>

      <%= form.submit "Search",
          class: "rounded-lg bg-indigo-600 px-6 py-3 text-white hover:bg-indigo-700" %>

    </div>

  <% end %>
</div>

<% end %>

<% if @ebooks.any? %>

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">

    <% @ebooks.each do |ebook| %>

      <div class="flex h-full flex-col overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-xl">

        <% if ebook.cover_image.attached? %>

          <%= image_tag ebook.cover_image,
              class: "h-72 w-full object-cover" %>

        <% else %>

          <div class="flex h-72 items-center justify-center bg-slate-100 text-6xl">
            📕
          </div>

        <% end %>

        <div class="flex flex-1 flex-col p-5">

          <h2 class="truncate text-lg font-semibold text-slate-900">
            <%= ebook.title %>
          </h2>

          <p class="mt-1 text-sm text-slate-600">
            <%= ebook.author %>
          </p>

          <% if ebook.description.present? %>

            <p class="mt-3 line-clamp-3 flex-1 text-sm text-slate-500">
              <%= ebook.description %>
            </p>

          <% else %>

            <p class="mt-3 flex-1 text-sm italic text-slate-400">
              No description available.
            </p>

          <% end %>

          <div class="mt-5">

            <%= link_to "View Details",
                ebook_path(ebook),
                class: "block w-full rounded-lg bg-indigo-600 py-2 text-center text-sm font-medium text-white transition hover:bg-indigo-700" %>

          </div>

        </div>

      </div>

    <% end %>

  </div>

<% else %>

  <%= render "shared/empty_state",
      title: "No ebooks yet",
      description: "Upload your first ebook." do %>

    <%= link_to "Upload Ebook",
        new_ebook_path,
        class: "rounded-lg bg-indigo-600 px-5 py-2.5 text-white transition hover:bg-indigo-700" %>

  <% end %>

<% end %>