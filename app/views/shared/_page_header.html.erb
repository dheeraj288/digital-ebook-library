<div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
  <div>
    <h1 class="text-3xl font-bold text-slate-900"><%= title %></h1>

    <% if subtitle.present? %>
      <p class="mt-2 text-slate-600"><%= subtitle %></p>
    <% end %>
  </div>

  <% if block_given? %>
    <div>
      <%= yield %>
    </div>
  <% end %>
</div>