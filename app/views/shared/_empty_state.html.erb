<div class="rounded-2xl border-2 border-dashed border-slate-300 bg-white py-16 text-center shadow-sm">
  <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full bg-indigo-100 text-4xl">
    📚
  </div>

  <h2 class="mt-6 text-2xl font-semibold text-slate-800">
    <%= title %>
  </h2>

  <p class="mt-2 text-slate-500">
    <%= description %>
  </p>

  <% if block_given? %>
    <div class="mt-8">
      <%= yield %>
    </div>
  <% end %>
</div>