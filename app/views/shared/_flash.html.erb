<% flash.each do |type, message| %>

  <% color_classes =
      case type.to_sym
      when :notice
        "border-green-500 bg-green-100 text-green-800"
      when :alert
        "border-red-500 bg-red-100 text-red-800"
      else
        "border-blue-500 bg-blue-100 text-blue-800"
      end
  %>

  <div
    data-controller="flash"
    class="mb-6 flex items-center justify-between rounded-lg border-l-4 p-4 shadow-sm transition-all duration-500 <%= color_classes %>">

    <p class="font-medium">
      <%= message %>
    </p>

    <button
      type="button"
      onclick="this.parentElement.remove()"
      class="ml-4 text-xl font-bold opacity-60 transition hover:opacity-100">
      ×
    </button>

  </div>

<% end %>